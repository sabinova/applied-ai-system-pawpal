%%{init: {"theme": "base", "themeVariables": {"fontFamily": "Inter, Segoe UI, Arial", "fontSize": "14px"}}}%%
classDiagram
    direction LR

    class Task {
        +str description
        +str time
        +int duration_minutes
        +str priority
        +str pet_name
        +str frequency
        +bool is_complete
        +str date
        +mark_complete() None
        +get_end_time() str
    }

    class Pet {
        +str name
        +str species
        +int age
        +list~Task~ tasks
        +add_task(task) None
        +get_tasks() list
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet) None
        +get_all_tasks() list
    }

    class Scheduler {
        +Owner owner
        +dict PRIORITY_WEIGHT
        +get_daily_schedule() list
        +sort_by_time(tasks) list
        +filter_by_status(tasks, complete) list
        +filter_by_pet(tasks, pet_name) list
        +detect_conflicts(tasks) list
        +handle_recurring(task) Task
        +mark_task_complete(task) None
    }

    Owner "1" *-- "*" Pet : owns
    Pet "1" *-- "*" Task : schedules
    Scheduler "1" --> "1" Owner : manages
