%%{init: {"theme": "base", "themeVariables": {"fontFamily": "Inter, Segoe UI, Arial", "fontSize": "14px"}, "flowchart": {"curve": "basis", "htmlLabels": true, "nodeSpacing": 40, "rankSpacing": 45}}}%%
flowchart TD
    %% ─── Entry point ───────────────────────────────────────────────
    UI["🐾 Streamlit UI<br/><i>pet description text</i>"]:::ui

    %% ─── Input guardrail ──────────────────────────────────────────
    InputGuard{{"Input Guardrail<br/><b>validate_user_input</b><br/><sub>length • pet vocab • injection</sub>"}}:::guard
    InputBlock["❌ Reject<br/><i>InvalidInputError</i>"]:::error

    %% ─── Agent subgraph ───────────────────────────────────────────
    subgraph Agent["🤖 ScheduleAgent.generate_schedule()"]
        direction TB
        S1["<b>Step 1 · Analyze</b><br/>LLM call"]:::llm
        Profile[("pet_profile JSON")]:::data
        S2["<b>Step 2 · Plan</b><br/>LLM call &nbsp;+&nbsp; tools"]:::llm
        Draft[("draft tasks")]:::data
        S3["<b>Step 3 · Validate</b><br/>tool: detect_conflicts"]:::tool
        ConflictDecision{"Conflicts<br/>found?"}:::decision
        IterDecision{"Revisions<br/>&lt; 3 ?"}:::decision
        S4["<b>Step 4 · Revise</b><br/>LLM call"]:::llm
        S5["<b>Step 5 · Quality scoring</b><br/>tool: calculate_schedule_quality"]:::tool
        Final[("finalized schedule")]:::data

        S1 --> Profile --> S2 --> Draft --> S3 --> ConflictDecision
        ConflictDecision -- "yes" --> IterDecision
        IterDecision -- "yes · loop back" --> S4
        S4 -- "revised draft" --> S3
        IterDecision -- "no · cap reached" --> S5
        ConflictDecision -- "no" --> S5
        S5 --> Final
    end

    %% ─── Output guardrail ─────────────────────────────────────────
    OutputGuard{{"Output Guardrail<br/><b>Pydantic ScheduleOutput</b><br/><sub>schema • types • duplicates</sub>"}}:::guard
    OutputFail["⚠ One revise retry,<br/>then fail closed"]:::error

    %% ─── Persistence layer ────────────────────────────────────────
    Persistence["🗄 <b>Persistence Layer (existing)</b><br/>Owner • Pet • Task • Scheduler"]:::persist

    %% ─── Wiring ──────────────────────────────────────────────────
    UI --> InputGuard
    InputGuard -- "invalid" --> InputBlock
    InputGuard -- "valid" --> Agent
    Final --> OutputGuard
    OutputGuard -- "invalid" --> OutputFail
    OutputGuard -- "valid" --> Persistence

    %% ─── Styling ─────────────────────────────────────────────────
    classDef ui        fill:#e3f2fd,stroke:#1976d2,stroke-width:1.5px,color:#0d47a1
    classDef guard     fill:#fff3e0,stroke:#ef6c00,stroke-width:1.5px,color:#e65100
    classDef llm       fill:#f3e5f5,stroke:#8e24aa,stroke-width:1.5px,color:#4a148c
    classDef tool      fill:#e8f5e9,stroke:#43a047,stroke-width:1.5px,color:#1b5e20
    classDef data      fill:#fafafa,stroke:#9e9e9e,stroke-width:1.2px,color:#212121
    classDef decision  fill:#fffde7,stroke:#f9a825,stroke-width:1.5px,color:#f57f17
    classDef error     fill:#ffebee,stroke:#c62828,stroke-width:1.5px,color:#b71c1c
    classDef persist   fill:#ede7f6,stroke:#5e35b1,stroke-width:1.8px,color:#311b92

    style Agent fill:#fbfbff,stroke:#7e57c2,stroke-width:2px,color:#311b92
